{
  "name": "git-trails",
  "version": "0.7.0",
  "description": "Trace exact line movement through Git commits",
  "type": "module",
  "license": "MIT",
  "author": "Alan Chen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheese-melted/git-trails.git"
  },
  "bugs": {
    "url": "https://github.com/cheese-melted/git-trails/issues"
  },
  "homepage": "https://github.com/cheese-melted/git-trails#readme",
  "keywords": [
    "git",
    "diff",
    "commit",
    "line-move",
    "code-tracking",
    "lineage",
    "refactoring",
    "patch"
  ],
  "bin": {
    "git-trails": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/*.json": "./schema/*.json"
  },
  "files": [
    "docs",
    "dist",
    "schema"
  ],
  "scripts": {
    "test": "bun test",
    "build": "rm -rf dist && bun build ./src/cli.ts ./src/index.ts --target=node --outdir=dist && tsc -p tsconfig.json",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  }
}
