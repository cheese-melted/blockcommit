{
  "name": "blockcommit",
  "version": "0.5.0",
  "description": "Convert git commits into line-move block digests",
  "type": "module",
  "license": "MIT",
  "author": "Alan Chen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheese-melted/blockcommit.git"
  },
  "bugs": {
    "url": "https://github.com/cheese-melted/blockcommit/issues"
  },
  "homepage": "https://github.com/cheese-melted/blockcommit#readme",
  "keywords": [
    "git",
    "diff",
    "commit",
    "line-move",
    "refactoring",
    "patch"
  ],
  "bin": {
    "blockcommit": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/*.json": "./schema/*.json"
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "test": "bun test",
    "build": "rm -rf dist && bun build ./src/cli.ts ./src/index.ts --target=node --outdir=dist && tsc -p tsconfig.json",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.0.0",
    "ajv": "^8.20.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=24"
  }
}
